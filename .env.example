# ============================================================
# WaveSpeed — https://wavespeed.ai/accesskey
# ============================================================
WAVESPEED_API_KEY=your-wavespeed-key-here

# Optional: override WaveSpeed API base
# WAVESPEED_API_BASE=https://api.wavespeed.ai

# ============================================================
# Fal.ai — https://fal.ai/dashboard/keys
# ============================================================
FAL_KEY=your-fal-key-here

# ============================================================
# Comfy API — https://platform.comfy.org/profile/api-keys
#
# This provider calls api.comfy.org directly (NO local ComfyUI process,
# NO Comfy Cloud subscription). It reverse-engineers the HTTP request
# that ComfyUI's GeminiImage2Node makes internally, so all you need is:
#
#   1. A comfy.org API key (format: comfyui-...)
#   2. API-node credits on your platform.comfy.org account (~$0.03-0.08
#      per Nano Banana Pro image, same ballpark as Fal)
#
# NOT required: ComfyUI install, Python, Comfy Cloud subscription.
# ============================================================
COMFY_API_KEY=your-comfy-key-here

# ============================================================
# Admin panel password — optional for dev, REQUIRED in production
# ============================================================
# If set, /admin/* routes require this password. It's never stored in
# plaintext — after login, the browser cookie holds a salted SHA-256
# hash of the password.
#
# Modes:
#   • Set in dev (NODE_ENV=development)     → password gate active
#   • Unset in dev (NODE_ENV=development)   → admin routes are OPEN (dev bypass)
#   • Set in production                     → password gate active
#   • Unset in production                   → admin routes return 503
#
# For extra security in production, additionally filter /admin/* and
# /api/admin/* at the reverse proxy layer (Caddy/nginx) to LAN/trusted
# IPs only. See middleware.ts for details.
#
# NOTE: Will be removed in Task 10.4 once Google-OAuth-based admin role
# fully supersedes the legacy password gate.
# ============================================================
ADMIN_PASSWORD=

# ============================================================
# History data directory — where SQLite DB and image files live
# ============================================================
# If set, wavespeed-claude reads/writes history to this directory.
# If unset, defaults to ./data (created automatically in project root).
#
# Expected layout:
#   $HISTORY_DATA_DIR/history.db         — SQLite database (auto-created)
#   $HISTORY_DATA_DIR/history_images/    — generated image files
#
# Schema is COMPATIBLE with viewcomfy-claude's lib/db.ts — both apps can
# safely share the same DB file (WAL mode allows concurrent readers +
# one writer). Records from viewcomfy will appear in wavespeed-claude's
# history for the same username, and vice versa.
#
# Dev example (default, unset):
#   # HISTORY_DATA_DIR=
#
# Container example (docker-compose volume mount):
#   HISTORY_DATA_DIR=/data
#   # volumes:
#   #   - C:/viewcomfy_data/database:/data    (Windows host)
#   #   - /opt/viewcomfy_data:/data           (Linux host)
# ============================================================
HISTORY_DATA_DIR=

# ============================================================
# Google OAuth — https://console.cloud.google.com/apis/credentials
# ============================================================
# Used by the auth flow under /api/auth/* (Authorization Code + PKCE
# + OIDC, id_token verified via JWKS with `jose`).
#
# Redirect URI must match the one registered in Google Cloud Console
# exactly (including scheme, host, port, path).
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ============================================================
# Sessions
# ============================================================
# 32+ bytes hex. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
SESSION_COOKIE_SECRET=

# ============================================================
# Initial admin allowlist (CSV emails). Idempotent: safe to leave on.
# ============================================================
# Each email listed here will be upserted as a user with role='admin'
# on app boot. Removing an email here does NOT demote an existing
# admin — manage roles via the admin UI after bootstrap.
# ============================================================
BOOTSTRAP_ADMIN_EMAILS=

# ============================================================
# Optional defense-in-depth: restrict OAuth to a single Google Workspace domain
# ============================================================
# If set, the callback rejects any id_token whose `hd` claim does not
# match this value. Leave unset to allow any Google account that
# matches BOOTSTRAP_ADMIN_EMAILS or admin-managed allowlist.
# ============================================================
# ALLOWED_HD=tapclap.com
